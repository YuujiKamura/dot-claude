import io
import ezdxf
import tempfile
import os

doc = ezdxf.new()
doc.encoding = 'utf-8'
msp = doc.modelspace()
msp.add_text('ABCµŚźµ£¼Ķ¬×XYZ', dxfattribs={'height': 2.5})

# ŃāĢŃéĪŃéżŃā½Ńü½õ┐ØÕŁśŃüŚŃü”ÕåŹĶ¬ŁŃü┐ĶŠ╝Ńü┐
with tempfile.NamedTemporaryFile(mode='w', suffix='.dxf', delete=False, encoding='utf-8') as f:
    tmp_path = f.name
    doc.saveas(tmp_path)

# ÕåŹĶ¬ŁŃü┐ĶŠ╝Ńü┐
doc2 = ezdxf.readfile(tmp_path)
for e in doc2.modelspace():
    if e.dxftype() == 'TEXT':
        print(f'Text: {e.dxf.text}')

os.unlink(tmp_path)
